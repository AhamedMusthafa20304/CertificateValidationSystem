# ═══════════════════════════════════════════════════════════════════
#  CertiVerifier – Environment Variables Template
#  Copy to .env and fill in your values:   cp .env.example .env
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── MySQL Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=certiverifier

# ── Sepolia RPC (pick one provider) ────────────────────────────────
# Infura  → https://infura.io   (free tier: 100k req/day)
# Alchemy → https://alchemy.com (free tier: 300M compute units/month)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# VITE_ prefix exposes variables to the browser build
VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ── Deployer wallet ─────────────────────────────────────────────────
# Export your MetaMask private key for the Hardhat deploy script.
# Use a dedicated test wallet – NEVER use a wallet holding real funds.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Contract address ────────────────────────────────────────────────
# Filled in automatically by scripts/deploy.ts after deployment.
CONTRACT_ADDRESS=
VITE_CONTRACT_ADDRESS=

# ── Etherscan (optional – only needed to verify contract source) ────
ETHERSCAN_API_KEY=

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
